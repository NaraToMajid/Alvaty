{
  "rewrites": [
    { "source": "/post/:id", "destination": "/view.html" },
    { "source": "/profile/:username", "destination": "/view.html" },
    { "source": "/reel/:id", "destination": "/view.html" },
    { "source": "/chat/:id", "destination": "/view.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
